{
  "name": "@tackpay/ddd",
  "version": "0.0.2",
  "description": "Domain Driven Design (DDD) library for TypeScript",
  "private": false,
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.mjs",
      "require": "./dist/common.js",
      "default": "./dist/common.mjs"
    }
  },
  "scripts": {
    "build": "run-s build:*",
    "build:clean": "rimraf dist",
    "build:compile": "tsup",
    "build:assets": "copyfiles --error -f package*.json dist/",
    "check": "run-p check:*",
    "check:types": "tsc --pretty --noEmit",
    "check:format": "prettier --check .",
    "check:lint": "pnpm biome check",
    "check:spelling": "cspell .",
    "check:packagejson": "npmPkgJsonLint .",
    "check:markdown": "markdownlint **/*.md",
    "check:staged": "lint-staged",
    "fix": "run-s fix:lint fix:format fix:markdown",
    "fix:format": "prettier --check --write --ignore-unknown .",
    "fix:lint": "pnpm biome lint --write",
    "fix:markdown": "markdownlint --fix ./**/*.md",
    "commit": "cz",
    "version": "standard-version -t",
    "reset-hard": "git clean -dfx && git reset --hard && pnpm install",
    "update-deps": "npm-check-updates -u",
    "prepare-release": "run-s reset-hard version",
    "test": "jest",
    "test:coverage": "pnpm test --coverage --silent",
    "prepare": "husky"
  },
  "keywords": [
    "typescript",
    "clean-code",
    "node",
    "starter",
    "project"
  ],
  "author": {
    "name": "Davide Barbieri",
    "email": "davidebarbieri109@gmail.com",
    "url": "https://github.com/dave19109"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "decimal.js": "^10.6.0",
    "lodash": "^4.17.23",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21",
    "type-fest": "^5.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/dict-bash": "^4.2.2",
    "@cspell/dict-companies": "^3.2.11",
    "@cspell/dict-en-gb": "^5.0.27",
    "@cspell/dict-filetypes": "^3.0.18",
    "@cspell/dict-html": "^4.0.15",
    "@cspell/dict-node": "^5.0.9",
    "@cspell/dict-npm": "^5.2.38",
    "@cspell/dict-software-terms": "^5.2.2",
    "@cspell/dict-typescript": "^3.2.3",
    "@swc/core": "^1.15.21",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "commitizen": "^4.3.1",
    "commitlint": "^20.5.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "cspell": "^9.7.0",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "get-tsconfig": "^4.13.7",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.48.0",
    "npm-check-updates": "^19.6.6",
    "npm-package-json-lint": "^10.0.0",
    "npm-package-json-lint-config-default": "^9.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "standard-version": "^9.5.0",
    "sync-dotenv": "^2.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.17.1"
  },
  "sync-dotenv": {
    "emptyLines": false,
    "comments": true
  }
}
